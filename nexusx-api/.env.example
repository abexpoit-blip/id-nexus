+# Server
PORT=8080
NODE_ENV=production
CORS_ORIGIN=https://buy.nexus-x.cloud

# Database (PostgreSQL on same VPS)
DATABASE_URL=postgres://nexusx_app:CHANGE_ME@127.0.0.1:5432/nexusx

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Admin bootstrap (first user with this email auto-becomes admin)
ADMIN_EMAIL=samexpoit@gmail.com

# Cookies
COOKIE_DOMAIN=.nexus-x.cloud
COOKIE_SECURE=true

# Uploads
UPLOAD_DIR=/var/www/nexusx-uploads
PUBLIC_UPLOAD_BASE=https://api.buy.nexus-x.cloud/uploads